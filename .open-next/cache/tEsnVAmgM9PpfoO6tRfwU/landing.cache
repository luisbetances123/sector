;, system-ui, sans-serif;min-height:100vh;overflow-x:hidden\"><nav style=\"position:fixed;top:0;left:0;right:0;z-index:100;padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;background:transparent;border-bottom:none;backdrop-filter:none;transition:all 0.3s\"><div style=\"font-weight:900;font-size:22px;letter-spacing:-1px\">SECTOR<span style=\"color:#CCFF00\">.</span></div><div style=\"display:flex;gap:36px;align-items:center\"><a href=\"#funciones\" style=\"color:#aaa;font-size:13px;text-decoration:none;font-weight:500\">Funciones</a><a href=\"/pricing\" style=\"color:#aaa;font-size:13px;text-decoration:none;font-weight:500\">Precios</a><a href=\"/login\" style=\"background:#CCFF00;color:#09090b;border-radius:100px;padding:9px 22px;font-size:13px;font-weight:800;text-decoration:none\">Acceder →</a></div></nav><section style=\"min-height:85vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 48px 60px\"><div style=\"font-size:11px;font-weight:700;letter-spacing:3px;color:#aaa;margin-bottom:28px;text-transform:uppercase\">🇩🇴   Plataforma Comercial · República Dominicana</div><h1 style=\"font-size:clamp(38px, 7vw, 84px);font-weight:900;letter-spacing:-3px;margin:0 0 28px;max-width:900px;line-height:1.05\">Tu inventario de preventa,<!-- --> <em style=\"color:#CCFF00;font-style:italic\">bajo tu control absoluto.</em></h1><p style=\"color:#aaa;font-size:clamp(15px, 1.8vw, 18px);max-width:560px;line-height:1.6;margin:0 0 44px;font-weight:400\">SECTOR conecta el inventario de tu constructora con el ejército de brokers de RD — en tiempo real, sin tocar tu ERP, desde cualquier celular.</p><div style=\"display:flex;gap:14px;flex-wrap:wrap;justify-content:center\"><a href=\"/login\" style=\"background:#CCFF00;color:#09090b;border-radius:100px;padding:16px 32px;font-weight:800;font-size:15px;text-decoration:none\">Acceder a SECTOR</a><a href=\"#funciones\" style=\"background:transparent;color:#fff;border-radius:100px;padding:16px 32px;font-weight:600;font-size:15px;text-decoration:none;border:1px solid #444\">Ver Funciones</a></div></section><section id=\"funciones\" style=\"padding:0 48px 100px\"><div style=\"text-align:center;margin-bottom:60px\"><div style=\"font-size:11px;font-weight:700;letter-spacing:3px;color:#aaa;margin-bottom:16px;text-transform:uppercase\">3 Módulos que Revolucionan la Preventa</div></div><div class=\"modules-grid\"><div style=\"background:#111113;border:1px solid #1a1a1d;border-radius:20px;padding:28px;display:flex;flex-direction:column\"><div style=\"background:#0d0d0f;border-radius:12px;padding:16px;border:1px solid #1a1a1d;margin-bottom:20px\"><div style=\"display:flex;gap:10px;margin-bottom:12px\"><div style=\"display:flex;align-items:center;gap:4px\"><div style=\"width:6px;height:6px;border-radius:2px;background:#22c55e\"></div><span style=\"color:#888;font-size:9px;text-transform:capitalize\">libre</span></div><div style=\"display:flex;align-items:center;gap:4px\"><div style=\"width:6px;height:6px;border-radius:2px;background:#f59e0b\"></div><span style=\"color:#888;font-size:9px;text-transform:capitalize\">reservado</span></div><div style=\"display:flex;align-items:center;gap:4px\"><div style=\"width:6px;height:6px;border-radius:2px;background:#ef4444\"></div><span style=\"color:#888;font-size:9px;text-transform:capitalize\">vendido</span></div></div><div style=\"margin-bottom:8px\"><div style=\"color:#555;font-size:9px;margin-bottom:4px;font-family:monospace\">Piso <!-- -->PH</div><div style=\"display:flex;gap:6px;flex-wrap:wrap\"><div style=\"background:#f59e0b;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">PH1</div><div style=\"background:#22c55e;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">PH2</div></div></div><div style=\"margin-bottom:8px\"><div style=\"color:#555;font-size:9px;margin-bottom:4px;font-family:monospace\">Piso <!-- -->4</div><div style=\"display:flex;gap:6px;flex-wrap:wrap\"><div style=\"background:#ef4444;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">4A</div><div style=\"background:#22c55e;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">4B</div><div style=\"background:#f59e0b;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">4C</div><div style=\"background:#22c55e;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">4D</div></div></div><div style=\"margin-bottom:8px\"><div style=\"color:#555;font-size:9px;margin-bottom:4px;font-family:monospace\">Piso <!-- -->1</div><div style=\"display:flex;gap:6px;flex-wrap:wrap\"><div style=\"background:#22c55e;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">1A</div><div style=\"background:#ef4444;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">1B</div><div style=\"background:#22c55e;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">1C</div><div style=\"background:#f59e0b;border-radius:6px;padding:5px 10px;color:#fff;font-weight:800;font-size:10px\">1D</div></div></div></div><div style=\"font-size:10px;font-weight:700;letter-spacing:3px;color:#CCFF00;text-transform:uppercase;margin-bottom:10px\">01</div><h3 style=\"font-size:clamp(18px, 2vw, 22px);font-weight:900;letter-spacing:-0.5px;margin:0 0 16px;color:#fff\">Mapa de Disponibilidad Real</h3><ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px\"><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Control visual de unidades</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Actualización al instante para brokers</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Filtrado por etapa de obra</li></ul></div><div style=\"background:#111113;border:1px solid #1a1a1d;border-radius:20px;padding:28px;display:flex;flex-direction:column\"><div style=\"background:#0d0d0f;border-radius:12px;padding:16px;border:1px solid #1a1a1d;margin-bottom:20px\"><div style=\"color:#555;font-size:9px;font-family:monospace;margin-bottom:10px\">sector.do/proyecto/torre-abc123</div><div style=\"display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #1a1a1d\"><div style=\"width:26px;height:26px;border-radius:50%;background:#1a1a1d;display:flex;align-items:center;justify-content:center;color:#CCFF00;font-weight:900;font-size:11px;flex-shrink:0\">R</div><div style=\"flex:1\"><div style=\"color:#eee;font-weight:600;font-size:11px\">Remax Capital</div><div style=\"color:#888;font-size:10px\">3<!-- --> unidades</div></div><div style=\"background:#CCFF0020;color:#CCFF00;border-radius:4px;padding:2px 8px;font-size:9px;font-weight:800\">Activo</div></div><div style=\"display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #1a1a1d\"><div style=\"width:26px;height:26px;border-radius:50%;background:#1a1a1d;display:flex;align-items:center;justify-content:center;color:#f59e0b;font-weight:900;font-size:11px;flex-shrink:0\">P</div><div style=\"flex:1\"><div style=\"color:#eee;font-weight:600;font-size:11px\">Plusval RD</div><div style=\"color:#888;font-size:10px\">1<!-- --> unidades</div></div><div style=\"background:#f59e0b20;color:#f59e0b;border-radius:4px;padding:2px 8px;font-size:9px;font-weight:800\">Activo</div></div><div style=\"display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #1a1a1d\"><div style=\"width:26px;height:26px;border-radius:50%;background:#1a1a1d;display:flex;align-items:center;justify-content:center;color:#4da6ff;font-weight:900;font-size:11px;flex-shrink:0\">L</div><div style=\"flex:1\"><div style=\"color:#eee;font-weight:600;font-size:11px\">Luis Betances</div><div style=\"color:#888;font-size:10px\">2<!-- --> unidades</div></div><div style=\"background:#4da6ff20;color:#4da6ff;border-radius:4px;padding:2px 8px;font-size:9px;font-weight:800\">Activo</div></div></div><div style=\"font-size:10px;font-weight:700;letter-spacing:3px;color:#CCFF00;text-transform:uppercase;margin-bottom:10px\">02</div><h3 style=\"font-size:clamp(18px, 2vw, 22px);font-weight:900;letter-spacing:-0.5px;margin:0 0 16px;color:#fff\">Intranet de Proyecto Segura</h3><ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px\"><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Acceso privado para agencias autorizadas</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Reservas de 48H con firma digital</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Trazabilidad total de ventas</li></ul></div><div style=\"background:#111113;border:1px solid #1a1a1d;border-radius:20px;padding:28px;display:flex;flex-direction:column\"><div style=\"background:#0d0d0f;border-radius:12px;padding:16px;border:1px solid #1a1a1d;margin-bottom:20px\"><div style=\"background:#1a1a1d;border-radius:10px;padding:12px;margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:8px\"><div style=\"color:#eee;font-weight:700;font-size:11px\">Torre Piantini</div><div style=\"color:#CCFF00;font-size:10px;font-weight:800\">65<!-- -->% obra</div></div><div style=\"background:#111;border-radius:3px;height:3px;margin-bottom:8px\"><div style=\"background:#CCFF00;height:3px;border-radius:3px;width:65%\"></div></div><div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;text-align:center\"><div><div style=\"color:#22c55e;font-weight:900;font-size:14px\">24</div><div style=\"color:#666;font-size:9px\">Libres</div></div><div><div style=\"color:#f59e0b;font-weight:900;font-size:14px\">8</div><div style=\"color:#666;font-size:9px\">Reservadas</div></div><div><div style=\"color:#ef4444;font-weight:900;font-size:14px\">40</div><div style=\"color:#666;font-size:9px\">Vendidas</div></div></div></div><div style=\"background:#1a1a1d;border-radius:10px;padding:12px;margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:8px\"><div style=\"color:#eee;font-weight:700;font-size:11px\">Residencias Naco</div><div style=\"color:#CCFF00;font-size:10px;font-weight:800\">30<!-- -->% obra</div></div><div style=\"background:#111;border-radius:3px;height:3px;margin-bottom:8px\"><div style=\"background:#CCFF00;height:3px;border-radius:3px;width:30%\"></div></div><div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;text-align:center\"><div><div style=\"color:#22c55e;font-weight:900;font-size:14px\">48</div><div style=\"color:#666;font-size:9px\">Libres</div></div><div><div style=\"color:#f59e0b;font-weight:900;font-size:14px\">5</div><div style=\"color:#666;font-size:9px\">Reservadas</div></div><div><div style=\"color:#ef4444;font-weight:900;font-size:14px\">15</div><div style=\"color:#666;font-size:9px\">Vendidas</div></div></div></div></div><div style=\"font-size:10px;font-weight:700;letter-spacing:3px;color:#CCFF00;text-transform:uppercase;margin-bottom:10px\">03</div><h3 style=\"font-size:clamp(18px, 2vw, 22px);font-weight:900;letter-spacing:-0.5px;margin:0 0 16px;color:#fff\">Gestión de Cobros y Postventa</h3><ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px\"><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Automatización de planes de pago</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Estados de cuenta interactivos para clientes</li><li style=\"display:flex;align-items:center;gap:10px;color:#aaa;font-size:13px;font-weight:500\"><div style=\"width:4px;height:4px;border-radius:50%;background:#CCFF00;flex-shrink:0\"></div>Portal de incidencias de entrega</li></ul></div></div></section><section style=\"background:#CCFF00;padding:60px 48px\"><div style=\"max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:0\"><div style=\"padding:20px 32px;border-left:none\"><div style=\"font-size:clamp(28px, 3.5vw, 48px);font-weight:900;color:#09090b;line-height:1;letter-spacing:-2px\">Tiempo real</div><div style=\"font-size:13px;color:rgba(0,0,0,0.6);margin-top:10px;line-height:1.5;white-space:pre-line;font-weight:500\">Disponibilidad sincronizada\nentre todos tus brokers.</div></div><div style=\"padding:20px 32px;border-left:1px solid rgba(0,0,0,0.15)\"><div style=\"font-size:clamp(28px, 3.5vw, 48px);font-weight:900;color:#09090b;line-height:1;letter-spacing:-2px\">0 apps</div><div style=\"font-size:13px;color:rgba(0,0,0,0.6);margin-top:10px;line-height:1.5;white-space:pre-line;font-weight:500\">El broker accede desde\nsu navegador. Sin instalar nada.</div></div><div style=\"padding:20px 32px;border-left:1px solid rgba(0,0,0,0.15)\"><div style=\"font-size:clamp(28px, 3.5vw, 48px);font-weight:900;color:#09090b;line-height:1;letter-spacing:-2px\">48 horas</div><div style=\"font-size:13px;color:rgba(0,0,0,0.6);margin-top:10px;line-height:1.5;white-space:pre-line;font-weight:500\">Reserva temporal automática.\nSin perder unidades.</div></div><div style=\"padding:20px 32px;border-left:1px solid rgba(0,0,0,0.15)\"><div style=\"font-size:clamp(28px, 3.5vw, 48px);font-weight:900;color:#09090b;line-height:1;letter-spacing:-2px\">0%</div><div style=\"font-size:13px;color:rgba(0,0,0,0.6);margin-top:10px;line-height:1.5;white-space:pre-line;font-weight:500\">Interferencia con\ntu ERP o contabilidad fiscal.</div></div></div></section><section style=\"padding:100px 48px;text-align:center;border-top:1px solid #1a1a1d\"><h2 style=\"font-size:clamp(32px, 5vw, 64px);font-weight:900;letter-spacing:-3px;margin:0 0 20px\">¿Listo para digitalizar<br/>tu fuerza de ventas?</h2><p style=\"color:#aaa;font-size:17px;max-width:440px;margin:0 auto 48px;line-height:1.6\">Sin tocar tu ERP. Sin cambiar tu contabilidad. Solo más ventas, más rápido.</p><div style=\"max-width:480px;margin:0 auto\"><div style=\"display:flex;gap:12px;flex-wrap:wrap;justify-content:center\"><input type=\"email\" placeholder=\"tu@constructora.com\" style=\"flex:1;min-width:240px;background:#111;border:1px solid #1a1a1d;color:#fff;border-radius:100px;padding:16px 24px;font-size:15px;outline:none\" value=\"\"/><button style=\"background:#CCFF00;color:#09090b;border-radius:100px;padding:16px 32px;font-weight:800;font-size:14px;border:none;cursor:pointer\">Solicitar Demo</button></div></div></section><footer style=\"background:#09090b;border-top:1px solid #1a1a1d;overflow:hidden\"><div style=\"padding:40px 48px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px\"><div style=\"font-weight:900;font-size:20px;letter-spacing:-1px\">SECTOR<span style=\"color:#CCFF00\">.</span></div><div style=\"color:#aaa;font-size:12px\">sector.do · Plataforma Comercial Inmobiliaria · República Dominicana · 2026</div></div><div style=\"font-size:clamp(80px, 18vw, 220px);font-weight:900;letter-spacing:-8px;color:#161619;line-height:0.85;padding:0 32px;user-select:none;margin-top:8px\">SECTOR</div></footer><style>\n        * { box-sizing: border-box; }\n        body { margin: 0; }\n        input::placeholder { color: #555; }\n        [data-vercel-toolbar], vercel-toolbar, #vercel-live-feedback { display: none !important; }\n        .modules-grid {\n          display: grid;\n          grid-template-columns: repeat(3, 1fr);\n          gap: 24px;\n          max-width: 1100px;\n          margin: 0 auto;\n        }\n        @media (max-width: 900px) {\n          .modules-grid { grid-template-columns: 1fr !important; }\n          nav a:not(:last-child) { display: none; }\n        }\n      </style></div><!--$--><!--/$--></div><script src=\"/_next/static/chunks/0n6p3.pxk1y1h.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[92825,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"ClientSegmentRoot\\\"]\\n3:I[42525,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"default\\\"]\\n4:I[39756,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"default\\\"]\\n5:I[37457,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"default\\\"]\\n7:I[47257,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"ClientPageRoot\\\"]\\n8:I[84073,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\",\\\"/_next/static/chunks/0d8fuq.6dadcs.js\\\",\\\"/_next/static/chunks/03n~psa9ls~h..js\\\"],\\\"default\\\"]\\nb:I[97367,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\\\"OutletBoundary\\\"]\\nc:\\\"$Sreact.suspense\\\"\\nf:I[97367,[\\\"/_next/static/chunks/0hx05ysdmb_~n.js\\\",\\\"/_next/static/chunks/06btg5few53ox.js\\\"],\