{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sector",
  "main": "worker-entry.js",
  "compatibility_date": "2026-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 13 * * *"]
  }
}
